SECRET_KEY=replace-this-with-a-new-production-secret-key
DJANGO_DEBUG=False
ALLOWED_HOSTS=your-render-service.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com

# Use this on Render/Railway when they provide a Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Or use these for local PostgreSQL when DATABASE_URL is blank.
DB_NAME=shields_aesthetics_db
DB_USER=postgres
DB_PASSWORD=replace-this-with-your-local-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

TIME_ZONE=Asia/Manila

# IMPORTANT for deployed apps:
# Uploaded patient/profile/service photos are not static files. The database
# stores the filename, but the actual image must live on persistent storage.
# On Render, add a persistent disk mounted at /var/data, then enable:
# MEDIA_ROOT=/var/data/media

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
